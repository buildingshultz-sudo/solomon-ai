async function runBrowserTask(instructions, options = {}) {
  try {
    const script = await callGPT4o(instructions);
    const timestamp = Date.now();
    const scriptPath = `/tmp/playwright-task-${timestamp}.js`;
    fs.writeFileSync(scriptPath, script);

    return new Promise((resolve, reject) => {
      exec(`node ${scriptPath}`, (error, stdout, stderr) => {
        if (error) {
          reject({ error, stderr });
        } else {
          resolve({ stdout, stderr });
        }
      });
    });

  } catch (error) {
    console.error('Error running browser task:', error);
    throw error;
  }
}

async function scrapeURL(url, extractionInstructions) {
  const browser = await playwright.chromium.launch();
  const context = await browser.newContext();
  const page = await context.newPage();
  await page.goto(url);

  const data = await page.evaluate(extractionInstructions);
  const screenshotPath = `/tmp/screenshot-${Date.now()}.png`;
  await page.screenshot({ path: screenshotPath });

  await browser.close();
  return { data, screenshotPath };
}

async function loginAndScrape(url, credentials, extractionInstructions) {
  const browser = await playwright.chromium.launch();
  const context = await browser.newContext();
  const page = await context.newPage();
  await page.goto(url);

  await page.fill(credentials.selector, credentials.value);
  await page.click(credentials.submitButton);

  const data = await page.evaluate(extractionInstructions);
  const screenshotPath = `/tmp/screenshot-${Date.now()}.png`;
  await page.screenshot({ path: screenshotPath });

  const cookies = await context.cookies();
  const domain = new URL(url).hostname;
  const sessionPath = `/root/solomon-bot/browser-sessions/${domain}.json`;
  fs.writeFileSync(sessionPath, JSON.stringify(cookies, null, 2));

  await browser.close();
  return { data, screenshotPath };
}

module.exports = {
  runBrowserTask,
  scrapeURL,
  loginAndScrape
};


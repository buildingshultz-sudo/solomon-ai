    saved_at: new Date().toISOString(),
    knowledge_base: loadKnowledgeBase(),
    reminders: loadReminders()
  };
  fs.writeFileSync(BACKUP_PATH, JSON.stringify(backup, null, 2));
  console.log('[BACKUP] Config saved');
}

// ─── DAILY CHECK-IN ──────────────────────────────────────────────────────────
let lastCheckinDate = null;

function shouldDoCheckin() {
  const now = new Date();
  const cdt = new Date(now.toLocaleString('en-US', { timeZone: 'America/Chicago' }));
  const today = `${cdt.getFullYear()}-${cdt.getMonth()}-${cdt.getDate()}`;
  if (lastCheckinDate === today) return false;
  if (cdt.getHours() === config.DAILY_CHECKIN_HOUR && cdt.getMinutes() >= config.DAILY_CHECKIN_MINUTE && cdt.getMinutes() < config.DAILY_CHECKIN_MINUTE + 5) {
    lastCheckinDate = today;
    return true;
  }
  return false;
}

async function dailyCheckin(bot) {
  try {
    const projects = loadProjects();
    const projectStatus = Object.entries(projects)
      .filter(([_, p]) => p.status === 'active')
      .map(([_, p]) => `${p.name}: ${p.phase} — Next: ${(p.nextSteps || []).slice(0, 2).join(', ')}`)
      .join('\n');

    const messages = [
      { role: 'system', content: config.SYSTEM_PROMPT + buildContext(config.OWNER_CHAT_ID) },
      { role: 'user', content: `Give me a brief morning check-in. Include: one motivational thought tied to my goals, current project status (IronEdit and others), what you worked on overnight, and one proactive suggestion for today. Keep it under 200 words. Be Sol.\n\nProject status:\n${projectStatus}` }
    ];
    const reply = await callLLM(messages);
    await safeSend(bot, config.OWNER_CHAT_ID, `☀️ *Morning Check-in*\n\n${reply}`);
    console.log('[CHECKIN] Daily check-in sent');
  } catch (e) { logError('daily_checkin', e); }
}

// ─── PROACTIVE WORK PROCESSOR ────────────────────────────────────────────────
let isProcessingWork = false;

async function processWorkQueue(bot) {
  if (isProcessingWork) return;
  isProcessingWork = true;

  try {
    const queue = loadWorkQueue();
    const pending = queue.items.filter(i => i.status === 'pending');
    if (pending.length === 0) { isProcessingWork = false; return; }

    const item = pending[0];
    item.status = 'processing';
    item.startedAt = Date.now();
    saveWorkQueue(queue);

    console.log(`[WORK] Processing: ${item.description}`);

    // Execute the work item
    if (item.type === 'pc_command') {
      const result = await executeOnPC(item.command, item.cmdType || 'powershell', item.timeout || 60000);
      item.result = result;
      item.status = result.success ? 'completed' : 'failed';
    } else if (item.type === 'dev_task') {
      // Multi-step dev task
      const results = await executeMultiOnPC(item.commands);
      item.results = results;
      item.status = results.every(r => r.success) ? 'completed' : 'partial';
    } else if (item.type === 'llm_task') {
      const result = await callLLM([
        { role: 'system', content: config.SYSTEM_PROMPT },
        { role: 'user', content: item.prompt }
      ]);
      item.result = result;
      item.status = 'completed';
    }

    item.completedAt = Date.now();
    saveWorkQueue(queue);

    // Notify Jed if it's a milestone
    if (item.notify) {
      await safeSend(bot, config.OWNER_CHAT_ID, `✅ *Work Complete:* ${item.description}\n\n${item.result?.output || item.result || '(done)'}`);
    }

    // Update project state if relevant
    if (item.project) {
      const projects = loadProjects();
      if (projects[item.project]) {
        projects[item.project].completedSteps.push(item.description);
        if (projects[item.project].nextSteps.length > 0) {
          projects[item.project].nextSteps.shift();
        }
        saveProjects(projects);
      }
    }
  } catch (e) {
    logError('work_queue', e);
  }

  isProcessingWork = false;
}

// ─── MAIN ─────────────────────────────────────────────────────────────────────
async function main() {
  console.log('🟢 Sol v5.0 starting (AUTONOMOUS + VISION + BROWSER)...');
  console.log(`   Model: ${config.MODEL}`);
  console.log(`   Memory: ${config.MAX_MESSAGES} messages`);
  console.log(`   Owner: ${config.OWNER_CHAT_ID}`);
  console.log(`   Workers: ${config.MAX_WORKERS}`);
  console.log(`   Work Queue: ${config.WORK_QUEUE_INTERVAL / 1000}s interval`);

  // Delete any webhook
  try {
    const delRes = await fetch(`https://api.telegram.org/bot${config.TELEGRAM_TOKEN}/deleteWebhook`);
    const delData = await delRes.json();
    console.log(`   Webhook deleted: ${delData.ok}`);
  } catch (e) { console.log('   Webhook delete failed (non-fatal)'); }

  // Initialize bot
  const bot = new TelegramBot(config.TELEGRAM_TOKEN, {
    polling: { interval: 300, autoStart: true, params: { timeout: 30 } }
  });

  bot.on('polling_error', (err) => {
    const code = err?.response?.statusCode;
    if (code === 409) return;
    logError('polling', err?.message || err);
  });

  console.log('🟢 Polling active. Listening for messages...');

  // ─── AUTONOMOUS WORKER INITIALIZATION ──────────────────────────────────────
  const workerDeps = {
    taskQueue: taskQueueModule,
    knowledgeBase: { loadKB, addToKB },
    core: { callLLM, webSearch, executeOnPC, safeSend }
  };
  const worker = initWorker(bot, config, workerDeps);
  console.log('[WORKER] Autonomous worker initialized');

  // ─── IRONEDIT PIPELINE ──────────────────────────────────────────────────────
  registerIronEditCommands(bot, { safeSend, executeOnPC, callLLM, taskQueueModule, addToKB });
  console.log('[IRONEDIT] Pipeline commands registered');

  // Crash recovery
  if (isRecoveredCrash) {
    setTimeout(async () => {
      await safeSend(bot, config.OWNER_CHAT_ID, '⚡ Sol back online — auto-recovered from crash. All systems nominal.');
    }, 5000);
  }

  saveBackupConfig();

  // ─── COMMAND: /start ────────────────────────────────────────────────────
  bot.onText(/^\/start$/, async (msg) => {
    await bot.sendMessage(msg.chat.id,
      `Sol v5.0 online. Full autonomy.\n\nGPT-4o Vision • Browser • SEO • PC Control • GitHub • Sub-agents\n\nCommands:\n/search — Web research\n/seo — Deep YouTube SEO analysis\n/browse — Open & read any URL\n/screenshot — Capture webpage\n/pc — PowerShell on PC\n/dev — Dev workflow\n/pcstatus — PC agent check\n/remind — Set reminder\n/remember — Store fact\n/tasks — Sub-tasks\n/projects — Active projects\n/status — System health\n/clear — Reset memory\n\nSend me any image — I can see and analyze it.\nOr just talk. I'm already working.`
    );
  });

  // ─── COMMAND: /clear ────────────────────────────────────────────────────
  bot.onText(/^\/clear$/, async (msg) => {
    db.prepare('DELETE FROM messages WHERE chat_id = ?').run(String(msg.chat.id));
    await bot.sendMessage(msg.chat.id, 'Conversation memory cleared. Knowledge base and projects retained.');
  });

  // ─── COMMAND: /status ───────────────────────────────────────────────────
  // OLD STATUS HANDLER REMOVED (replaced by autonomous version)

  // ─── COMMAND: /projects ─────────────────────────────────────────────────
  bot.onText(/^\/projects$/, async (msg) => {
    const projects = loadProjects();
    let text = '📁 *Active Projects*\n\n';
    for (const [key, p] of Object.entries(projects)) {
      if (p.status !== 'active') continue;
      text += `*${p.name}* [${p.phase}]\n`;
      text += `  Status: ${p.status}\n`;
      if (p.completedSteps?.length) text += `  Done: ${p.completedSteps.length} steps\n`;
      if (p.nextSteps?.length) text += `  Next: ${p.nextSteps.slice(0, 3).join(' → ')}\n`;
      text += `  Updated: ${p.lastUpdated}\n\n`;
    }
    await safeSend(bot, msg.chat.id, text);
  });

  // ─── COMMAND: /tasks ────────────────────────────────────────────────────
  bot.onText(/^\/tasks$/, async (msg) => {
    const wq = loadWorkQueue();
    let text = '📋 *Tasks & Work Queue*\n\n';
    if (activeTasks.length > 0) text += '*Active sub-tasks:*\n' + activeTasks.map(t => `• 🔄 ${t.description}`).join('\n') + '\n\n';
    if (taskQueue.length > 0) text += '*Queued:*\n' + taskQueue.map(t => `• ⏳ ${t.description}`).join('\n') + '\n\n';
    const pending = wq.items?.filter(i => i.status === 'pending') || [];
    if (pending.length > 0) text += '*Work queue:*\n' + pending.slice(0, 10).map(w => `• 📌 ${w.description}`).join('\n') + '\n\n';
    if (completedTasks.length > 0) text += '*Recent completed:*\n' + completedTasks.slice(-5).map(t => `• ✓ ${t.description}`).join('\n');
    if (text === '📋 *Tasks & Work Queue*\n\n') text += 'No active tasks or work items.';
    await safeSend(bot, msg.chat.id, text);
  });

  // ─── COMMAND: /pc ───────────────────────────────────────────────────────
  bot.onText(/^\/pc (.+)/, async (msg, match) => {
    const chatId = msg.chat.id;
    const command = match[1];
    console.log(`[CMD] /pc from ${chatId}: ${command}`);
    await bot.sendChatAction(chatId, 'typing');
    const result = await executeOnPC(command);
    const sym = result.success ? '✓' : '✗';
    await safeSend(bot, chatId, `${sym} *PC:* \`${command.slice(0, 100)}\`\n\n\`\`\`\n${result.output.slice(0, 3000)}\n\`\`\``);
  });

  // ─── COMMAND: /dev ──────────────────────────────────────────────────────
  bot.onText(/^\/dev (.+)/, async (msg, match) => {
    const chatId = msg.chat.id;
    const instruction = match[1];
    console.log(`[CMD] /dev from ${chatId}: ${instruction}`);
    await bot.sendChatAction(chatId, 'typing');

    // Let Sol interpret the dev instruction and generate commands
    const messages = [
      { role: 'system', content: `You are Sol's dev executor. Convert this development instruction into a PowerShell or CMD command that can run on Windows. The PC has Node.js, Python, Git, npm installed. User is Ashle, desktop at C:\\Users\\Ashle\\Desktop. Respond with ONLY the command, no explanation.` },
      { role: 'user', content: instruction }
    ];
    try {
      const cmd = await callLLM(messages, config.MODEL_FALLBACK, 0);
      const cleanCmd = cmd.replace(/```[\s\S]*?```/g, '').replace(/`/g, '').trim().split('\n')[0];
      const result = await executeOnPC(cleanCmd, 'cmd', 120000);
      await safeSend(bot, chatId, `🔧 *Dev:* \`${cleanCmd.slice(0, 100)}\`\n\n\`\`\`\n${result.output.slice(0, 3000)}\n\`\`\``);
    } catch (e) {
      logError('dev_cmd', e);
      await safeSend(bot, chatId, 'Dev command failed. Try /pc for direct PowerShell.');
    }
  });

  // ─── COMMAND: /pcstatus ─────────────────────────────────────────────────
  bot.onText(/^\/pcstatus$/, async (msg) => {

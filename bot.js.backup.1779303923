      await bot.sendMessage(msg.chat.id, `🖥️ PC Agent: ONLINE (heartbeat ${ago}s ago)`);
    } else {
      await bot.sendMessage(msg.chat.id, '🖥️ PC Agent: OFFLINE\n\nMake sure solomon-agent.js is running on your PC.');
    }
  });


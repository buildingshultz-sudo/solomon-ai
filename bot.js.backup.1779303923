  // ─── PHOTO/IMAGE HANDLER (Vision) ─────────────────────────────────────
// ─── IMAGE GENERATION (DALL-E 3 via OpenRouter + Flux via BFL) ──────────────
async function generateImageDALLE(prompt) {
  try {
    const res = await fetch('https://api.openai.com/v1/images/generations', {
      method: 'POST',
      signal: AbortSignal.timeout(60000),
      headers: {
        'Authorization': `Bearer ${config.OPENROUTER_API_KEY}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        model: 'dall-e-3',
        prompt: prompt,
        n: 1,
        size: '1024x1024',
        quality: 'standard'
      })
    });
    if (!res.ok) {
      // Try via OpenRouter image generation endpoint
      const orRes = await fetch('https://openrouter.ai/api/v1/images/generations', {
        method: 'POST',
        signal: AbortSignal.timeout(60000),
        headers: {
          'Authorization': `Bearer ${config.OPENROUTER_API_KEY}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          model: 'openai/dall-e-3',
          prompt: prompt,
          n: 1,
          size: '1024x1024'
        })
      });
      if (!orRes.ok) throw new Error(`Image gen failed: ${orRes.status}`);
      const orData = await orRes.json();
      return { success: true, url: orData.data?.[0]?.url };
    }
    const data = await res.json();
    return { success: true, url: data.data?.[0]?.url };
  } catch (e) {
    logError('dalle', e);
    return { success: false, error: e.message };
  }
}

async function generateImageFlux(prompt) {
  if (!config.BFL_API_KEY) return { success: false, error: 'BFL API key not configured. Set BFL_API_KEY in config.' };
  try {
    const res = await fetch(config.BFL_URL, {
      method: 'POST',
      signal: AbortSignal.timeout(90000),
      headers: {
        'Authorization': `Bearer ${config.BFL_API_KEY}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ prompt, width: 1024, height: 1024 })
    });
    if (!res.ok) throw new Error(`Flux API ${res.status}`);
    const data = await res.json();
    // BFL returns a task ID, need to poll for result
    if (data.id) {
      const pollUrl = `https://api.bfl.ai/v1/get_result?id=${data.id}`;
      for (let i = 0; i < 30; i++) {
        await new Promise(r => setTimeout(r, 3000));
        const pRes = await fetch(pollUrl, { headers: { 'Authorization': `Bearer ${config.BFL_API_KEY}` } });
        const pData = await pRes.json();
        if (pData.status === 'Ready' && pData.result?.sample) {
          return { success: true, url: pData.result.sample };
        }
        if (pData.status === 'Error') throw new Error('Flux generation failed');
      }
      throw new Error('Flux generation timed out');
    }
    return { success: true, url: data.sample || data.url || data.image_url };
  } catch (e) {
    logError('flux', e);
    return { success: false, error: e.message };
  }
}

// ─── WEB SEARCH (DuckDuckGo HTML scraping) ──────────────────────────────────
async function webSearch(query, maxResults = 5) {
  try {
    // Use DuckDuckGo HTML endpoint
    const url = `https://html.duckduckgo.com/html/?q=${encodeURIComponent(query)}`;
    const res = await fetch(url, {
      signal: AbortSignal.timeout(15000),
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36'
      }
    });
    if (!res.ok) throw new Error(`Search failed: ${res.status}`);
    const html = await res.text();
    
    // Parse results from HTML
    const results = [];
    const resultRegex = /<a rel="nofollow" class="result__a" href="([^"]+)"[^>]*>(.+?)<\/a>[\s\S]*?<a class="result__snippet"[^>]*>([\s\S]*?)<\/a>/g;
    let match;
    while ((match = resultRegex.exec(html)) !== null && results.length < maxResults) {
      const href = match[1];
      const title = match[2].replace(/<[^>]+>/g, '').trim();
      const snippet = match[3].replace(/<[^>]+>/g, '').trim();
      // Decode DuckDuckGo redirect URL
      let realUrl = href;
      if (href.includes('uddg=')) {
        try { realUrl = decodeURIComponent(href.split('uddg=')[1].split('&')[0]); } catch {}
      }
      results.push({ title, url: realUrl, snippet });
    }
    
    if (results.length === 0) {
      // Fallback: simpler regex
      const simpleRegex = /<a[^>]*class="result__url"[^>]*href="([^"]+)"[^>]*>([^<]*)<\/a>/g;
      const snippetRegex = /<a[^>]*class="result__snippet"[^>]*>([\s\S]*?)<\/a>/g;
      let urlMatch, snippetMatch;
      while ((urlMatch = simpleRegex.exec(html)) !== null && results.length < maxResults) {
        snippetMatch = snippetRegex.exec(html);
        results.push({
          title: urlMatch[2].trim() || 'Result',
          url: urlMatch[1],
          snippet: snippetMatch ? snippetMatch[1].replace(/<[^>]+>/g, '').trim() : ''
        });
      }
    }
    
    return { success: true, results, query };
  } catch (e) {
    logError('web_search', e);
    return { success: false, error: e.message, results: [] };
  }
}

// ─── DAVINCI RESOLVE CONTROL ────────────────────────────────────────────────
async function resolveEdit(action, params = {}) {
  const scripts = {
    launch: 'Start-Process "C:\\Program Files\\Blackmagic Design\\DaVinci Resolve\\Resolve.exe" -ErrorAction SilentlyContinue; Start-Sleep 10; Write-Output "DaVinci Resolve launched"',
    status: 'Get-Process -Name "Resolve" -ErrorAction SilentlyContinue | Select-Object ProcessName, Id, CPU | Format-Table | Out-String',
    import_media: `$resolve = [System.Runtime.InteropServices.Marshal]::GetActiveObject("DaVinciResolve.Application"); $pm = $resolve.GetProjectManager(); $proj = $pm.GetCurrentProject(); $mp = $proj.GetMediaPool(); $mp.ImportMedia(@("${params.path || ''}")); Write-Output "Media imported"`,
    open_project: `$resolve = [System.Runtime.InteropServices.Marshal]::GetActiveObject("DaVinciResolve.Application"); $pm = $resolve.GetProjectManager(); $proj = $pm.LoadProject("${params.name || ''}"); Write-Output "Project opened: ${params.name || ''}"`,
    render: `$resolve = [System.Runtime.InteropServices.Marshal]::GetActiveObject("DaVinciResolve.Application"); $pm = $resolve.GetProjectManager(); $proj = $pm.GetCurrentProject(); $proj.SetRenderSettings(@{TargetDir="${params.output || 'C:\\Users\\Ashle\\Desktop\\Renders'}"}); $proj.AddRenderJob(); $proj.StartRendering(); Write-Output "Render started"`,
    list_projects: '$resolve = [System.Runtime.InteropServices.Marshal]::GetActiveObject("DaVinciResolve.Application"); $pm = $resolve.GetProjectManager(); $pm.GetProjectListInCurrentFolder() | ForEach-Object { Write-Output $_ }',
    timeline_info: '$resolve = [System.Runtime.InteropServices.Marshal]::GetActiveObject("DaVinciResolve.Application"); $pm = $resolve.GetProjectManager(); $proj = $pm.GetCurrentProject(); $tl = $proj.GetCurrentTimeline(); Write-Output "Timeline: $($tl.GetName()) | Tracks: $($tl.GetTrackCount(\"video\")) video, $($tl.GetTrackCount(\"audio\")) audio | Duration: $($tl.GetEndFrame() - $tl.GetStartFrame()) frames"'
  };
  
  const script = scripts[action];
  if (!script) return { success: false, output: `Unknown action: ${action}. Available: ${Object.keys(scripts).join(', ')}` };
  
  return await executeOnPC(script, 'powershell', 30000);
}


  // ─── COMMAND: /imagine (DALL-E 3) ──────────────────────────────────────────
  bot.onText(/^\/imagine(?:-flux)?\s+(.+)/s, async (msg, match) => {
    const chatId = msg.chat.id;
    const prompt = match[1].trim();
    const isFlux = msg.text.startsWith('/imagine-flux');
    
    await safeSend(bot, chatId, `🎨 Generating image${isFlux ? ' (Flux)' : ' (DALL-E 3)'}...\n_Prompt: "${prompt.slice(0, 100)}"_`);
    await bot.sendChatAction(chatId, 'upload_photo');
    
    const result = isFlux ? await generateImageFlux(prompt) : await generateImageDALLE(prompt);
    
    if (result.success && result.url) {
      try {
        await bot.sendPhoto(chatId, result.url, { caption: `🎨 "${prompt.slice(0, 200)}"` });
      } catch (sendErr) {
        // If sending URL fails, try downloading first
        try {
          const imgRes = await fetch(result.url);
          const buffer = Buffer.from(await imgRes.arrayBuffer());
          await bot.sendPhoto(chatId, buffer, { caption: `🎨 "${prompt.slice(0, 200)}"` });
        } catch (e2) {
          await safeSend(bot, chatId, `Image generated but couldn't send it. URL: ${result.url}`);
        }
      }
    } else {
      await safeSend(bot, chatId, `❌ Image generation failed: ${result.error || 'Unknown error'}\n\nTip: Make sure the API key has image generation access.`);
    }
  });

  // ─── COMMAND: /edit (DaVinci Resolve) ─────────────────────────────────────
  bot.onText(/^\/edit(?:\s+(.+))?/, async (msg, match) => {
    const chatId = msg.chat.id;
    const args = (match[1] || '').trim();
    
    if (!args) {
      await safeSend(bot, chatId, `🎬 *DaVinci Resolve Editor*\n\nUsage:\n• /edit status — Check if Resolve is running\n• /edit launch — Start DaVinci Resolve\n• /edit projects — List available projects\n• /edit open [name] — Open a project\n• /edit import [path] — Import media file\n• /edit timeline — Current timeline info\n• /edit render — Start rendering current timeline\n\nOr describe what you want edited and I'll build the workflow.`);
      return;
    }
    
    const parts = args.split(/\s+/);
    const action = parts[0].toLowerCase();
    const param = parts.slice(1).join(' ');
    
    const directActions = ['status', 'launch', 'list_projects', 'timeline_info', 'render'];
    const paramActions = { 'open': 'open_project', 'import': 'import_media', 'projects': 'list_projects', 'timeline': 'timeline_info' };
    
    let resolveAction = paramActions[action] || action;
    let params = {};
    if (action === 'open') params = { name: param };
    else if (action === 'import') params = { path: param };
    else if (action === 'render') params = { output: param || 'C:\\Users\\Ashle\\Desktop\\Renders' };
    
    if (directActions.includes(resolveAction) || Object.values(paramActions).includes(resolveAction)) {
      await bot.sendChatAction(chatId, 'typing');
      const result = await resolveEdit(resolveAction, params);
      await safeSend(bot, chatId, `🎬 *Resolve — ${action}*\n\n\`\`\`\n${result.output || 'No output'}\n\`\`\``);
    } else {
      // Natural language edit request — use LLM to plan the workflow
      await bot.sendChatAction(chatId, 'typing');
      const messages = [
        { role: 'system', content: config.SYSTEM_PROMPT },
        { role: 'user', content: `I want to edit video in DaVinci Resolve. Here's what I need: ${args}\n\nPlan the steps using DaVinci Resolve scripting API. Be specific about what commands to run.` }
      ];
      const plan = await callLLM(messages);
      await safeSend(bot, chatId, `🎬 *Edit Plan:*\n\n${plan}`);
    }
  });


  // ─── COMMAND: /queue ────────────────────────────────────────────────────────
  bot.onText(/^\/queue$/, async (msg) => {
    const chatId = msg.chat.id;
    const summary = taskQueueModule.getQueueSummary();
    let response = '📋 *Task Queue*\n\n';
    
    if (summary.active.length > 0) {
      response += '*Active:*\n';
      summary.active.forEach(t => {
        response += `⚡ ${t.title} — ${t.progress}% (step ${t.currentStep}/${t.totalSteps})\n`;
      });
    }
    
    if (summary.pending.length > 0) {
      response += '\n*Pending:*\n';
      summary.pending.slice(0, 5).forEach((t, i) => {
        response += `${i + 1}. [P${t.priority}] ${t.title}\n`;
      });
      if (summary.pending.length > 5) response += `   ...and ${summary.pending.length - 5} more\n`;
    }
    
    if (summary.completed.length > 0) {
      response += '\n*Recently Completed:*\n';
      summary.completed.slice(-3).forEach(t => {
        const ago = Math.round((Date.now() - t.completedAt) / 60000);
        response += `✅ ${t.title} (${ago}m ago)\n`;
      });
    }
    
    if (summary.active.length === 0 && summary.pending.length === 0) {
      response += '_Queue empty. I\'ll proactively add tasks based on business priorities._';
    }
    
    response += `\n\n📊 Stats: ${summary.stats.completed} completed, ${summary.stats.failed} failed, ${summary.stats.total} total`;
    await safeSend(bot, chatId, response);
  });

  // ─── COMMAND: /memory ───────────────────────────────────────────────────────
  bot.onText(/^\/memory(?:\s+(.+))?/, async (msg, match) => {
    const chatId = msg.chat.id;
    const args = (match[1] || '').trim();
    
    if (!args) {
      await safeSend(bot, chatId, getFullKBReport());
      return;
    }
    
    if (args.startsWith('add ')) {
      const parts = args.slice(4).split(' ');
      const category = parts[0];
      const info = parts.slice(1).join(' ');
      if (!category || !info) {
        await safeSend(bot, chatId, 'Usage: /memory add [category] [info]\nCategories: research_findings, lessons_learned, content_ideas, next_moves');
        return;
      }
      addToKB(category, { title: info, addedBy: 'manual', date: new Date().toISOString() });
      await safeSend(bot, chatId, `✅ Added to ${category}: "${info}"`);
      return;
    }
    
    // Show specific category
    const kb = loadKB();
    if (kb[args]) {
      const data = kb[args];
      const display = Array.isArray(data) ? data.slice(-10).map(d => `• ${d.title || d.lesson || d.decision || JSON.stringify(d).slice(0, 100)}`).join('\n') : JSON.stringify(data, null, 2).slice(0, 2000);
      await safeSend(bot, chatId, `📚 *${args}:*\n${display}`);
    } else {
      await safeSend(bot, chatId, `Unknown category. Available: ${Object.keys(kb).join(', ')}`);
    }
  });

  // ─── COMMAND: /status (OVERHAULED) ──────────────────────────────────────────
  bot.onText(/^\/status$/, async (msg) => {
    const chatId = msg.chat.id;
    const summary = taskQueueModule.getQueueSummary();
    const uptime = process.uptime();
    const uptimeStr = uptime > 3600 ? `${Math.floor(uptime/3600)}h ${Math.floor((uptime%3600)/60)}m` : `${Math.floor(uptime/60)}m`;
    
    let status = '📊 *Sol Status*\n\n';
    
    // Current work
    if (summary.active.length > 0) {
      const t = summary.active[0];
      status += `*Working on:* ${t.title} (${t.progress}% — step ${t.currentStep}/${t.totalSteps})\n`;
    } else {
      status += '*Working on:* Nothing active (checking queue every 60s)\n';
    }
    
    // Queue
    status += `*Queue:* ${summary.pending.length} pending`;
    if (summary.pending.length > 0) {
      status += ` — next: ${summary.pending[0].title}`;
    }
    status += '\n';
    
    // Last completed
    if (summary.completed.length > 0) {
      const last = summary.completed[summary.completed.length - 1];
      const ago = Math.round((Date.now() - last.completedAt) / 60000);
      status += `*Last completed:* ${last.title} (${ago}m ago)\n`;
    }
    
    // System health
    status += `\n*Uptime:* ${uptimeStr}\n`;
    status += `*Model:* ${config.MODEL}\n`;
    status += `*Tasks completed:* ${summary.stats.completed}/${summary.stats.total}\n`;
    
    await safeSend(bot, chatId, status);
  });

  // ─── COMMAND: /addtask ──────────────────────────────────────────────────────
  bot.onText(/^\/addtask\s+(.+)/s, async (msg, match) => {
    const chatId = msg.chat.id;
    const desc = match[1].trim();
    const task = taskQueueModule.addTask({
      title: desc.slice(0, 100),
      description: desc,
      type: 'research',
      priority: 5
    });
    await safeSend(bot, chatId, `✅ Task added: "${task.title}"\nID: ${task.id}\nPosition: will execute based on priority.`);
  });

  // ─── COMMAND: /websearch ──────────────────────────────────────────────────
  bot.onText(/^\/websearch\s+(.+)/s, async (msg, match) => {
    const chatId = msg.chat.id;
    const query = match[1].trim();
    
    await bot.sendChatAction(chatId, 'typing');
    const searchResult = await webSearch(query, 8);
    
    if (searchResult.success && searchResult.results.length > 0) {
      let response = `🔍 *Web Search: "${query}"*\n\n`;
      searchResult.results.forEach((r, i) => {
        response += `${i + 1}. **${r.title}**\n${r.snippet}\n🔗 ${r.url}\n\n`;
      });
      await safeSend(bot, chatId, response);
    } else {
      await safeSend(bot, chatId, `🔍 No results found for "${query}". ${searchResult.error || ''}`);
    }
  });


  
// /updateagent — Sol self-updates his PC agent code
bot.onText(/^\/updateagent(?:\s+([\s\S]+))?$/i, async (msg, match) => {
  const chatId = msg.chat.id;
  if (chatId.toString() !== config.OWNER_CHAT_ID.toString()) return;
  const subCmd = (match[1] || '').trim().toLowerCase();
  if (subCmd === 'status') {
    const s = await pcAgentStatus();
    return safeSend(bot, chatId, s.online
      ? '✅ PC Agent is ONLINE. Last heartbeat: ' + new Date(s.lastHeartbeat).toLocaleTimeString()
      : '❌ PC Agent is OFFLINE.');
  }
  if (subCmd === 'check') {
    // Check watchdog is running
    const r = await executeOnPC('Get-Process wscript -ErrorAction SilentlyContinue | Where-Object { $_.MainWindowTitle -eq \'\' } | Select-Object Id, CPU | Format-Table | Out-String', 'powershell', 15000);
    return safeSend(bot, chatId, '🔍 Watchdog check:\n' + (r.output || 'No output'));
  }
  return safeSend(bot, chatId,
    '🔧 *PC Agent Self-Update Commands:*\n' +
    '`/updateagent status` — Check if agent is online\n' +
    '`/updateagent check` — Verify watchdog is running\n\n' +
    'To update agent code, I write the new file and the watchdog auto-restarts me.\n' +
    'I NEVER kill node.exe directly — that would kill my own connection.');
});

bot.on('photo', async (msg) => {
    const chatId = msg.chat.id;
    console.log(`[PHOTO] from ${chatId}`);
    await bot.sendChatAction(chatId, 'typing');
    try {
      const photo = msg.photo[msg.photo.length - 1];
      const fileLink = await bot.getFileLink(photo.file_id);
      const caption = msg.caption || '';
      const analysis = await analyzeImage(fileLink, caption);
      saveMessage(chatId, 'user', `[Image sent] ${caption}`);
      saveMessage(chatId, 'assistant', analysis);
      await safeSend(bot, chatId, analysis);
      if (caption.toLowerCase().includes('thumbnail') || caption.toLowerCase().includes('thumb')) {
        addToStyleGuide('analyses', { caption, analysis: analysis.slice(0, 500), source: 'user_upload' });
        await safeSend(bot, chatId, '_✔ Added to thumbnail style guide._');
      }
    } catch (e) {
      logError('photo_handler', e);
      await safeSend(bot, chatId, 'Had trouble analyzing that image. Try again.');
    }
  });

  // ─── VOICE MESSAGES ────────────────────────────────────────────────────
  bot.on('voice', async (msg) => {
    const chatId = msg.chat.id;
    console.log(`[VOICE] from ${chatId}`);
    await bot.sendChatAction(chatId, 'typing');
    const transcript = await transcribeVoice(bot, msg.voice.file_id);
    if (!transcript || transcript.startsWith('[')) {
      await bot.sendMessage(chatId, transcript || 'Could not process voice.');
      return;
    }
    await handleText(bot, chatId, transcript, `🎤 *"${transcript}"*\n\n`);
  });

  // ─── REGULAR MESSAGES ──────────────────────────────────────────────────
  bot.on('message', async (msg) => {
    if (!msg.text || msg.text.startsWith('/')) return;
    if (msg.voice || msg.photo) return;
    const chatId = msg.chat.id;
    console.log(`[MSG] from ${chatId}: ${msg.text.slice(0, 80)}`);
    await bot.sendChatAction(chatId, 'typing');
    await handleText(bot, chatId, msg.text);
  });

  // ─── REMINDER CHECKER (every 30s) ─────────────────────────────────────
  setInterval(() => {
    const reminders = loadReminders();
    const now = Date.now();
    const due = reminders.filter(r => r.triggerTime <= now);
    const remaining = reminders.filter(r => r.triggerTime > now);
    if (due.length > 0) {
      saveReminders(remaining);
      for (const r of due) { safeSend(bot, r.chatId, `⏰ *Reminder:* ${r.text}`); }
    }
  }, 30000);

  // ─── HEALTH CHECK (every 60s) ──────────────────────────────────────────
  setInterval(() => { healthCheck(bot).catch(e => logError('health_interval', e)); }, 60000);

  // ─── DAILY CHECK-IN (every minute) ─────────────────────────────────────
  setInterval(() => {
    if (shouldDoCheckin()) dailyCheckin(bot).catch(e => logError('checkin', e));
  }, 60000);

  // ─── PROACTIVE WORK QUEUE (every 5 min) ────────────────────────────────

  // ─── WEEKLY BUSINESS INTELLIGENCE BRIEF (Mondays 6 AM CDT) ─────────────────
  let lastWeeklyBriefDate = null;
  setInterval(async () => {
    try {
      const now = new Date();
      const cdt = new Date(now.toLocaleString('en-US', { timeZone: 'America/Chicago' }));
      const isMonday = cdt.getDay() === 1;
      const isRightHour = cdt.getHours() === 6 && cdt.getMinutes() < 5;
      const weekKey = `${cdt.getFullYear()}-W${Math.ceil(cdt.getDate()/7)}`;
      if (!isMonday || !isRightHour || lastWeeklyBriefDate === weekKey) return;
      lastWeeklyBriefDate = weekKey;
      console.log('[WEEKLY_BRIEF] Generating Business Intelligence Brief...');
      const projects = loadProjects();
      const kb = loadKnowledgeBase();
      const NEXT_MOVES_PATH = path.join(__dirname, 'next_moves.json');
      let moves = { items: [] };
      if (fs.existsSync(NEXT_MOVES_PATH)) { try { moves = JSON.parse(fs.readFileSync(NEXT_MOVES_PATH, 'utf8')); } catch {} }
      const messages = [
        { role: 'system', content: config.SYSTEM_PROMPT },
        { role: 'user', content: `Generate this week's Business Intelligence Brief for Shultz Enterprises. Monday morning.\n\nActive projects: ${JSON.stringify(Object.values(projects).filter(p=>p.status==='active').map(p=>({name:p.name,phase:p.phase})))}\nRecent decisions: ${JSON.stringify(kb.decisions?.slice(-3)||[])}\nLast Next Moves: ${moves.items?.[0]?.text?.slice(0,400)||'none'}\n\nBrief (under 300 words):\n1. WEEK IN REVIEW\n2. THIS WEEK PRIORITIES (top 3)\n3. OPPORTUNITIES SPOTTED\n4. WATCH LIST\n5. PROACTIVE SUGGESTION\n\nSharp. Direct. Chief of Staff thinking.` }
      ];
      const brief = await callLLM(messages);
      const dateStr = cdt.toLocaleDateString('en-US', {weekday:'long', month:'long', day:'numeric'});
      await safeSend(bot, config.OWNER_CHAT_ID, `\u{1F4CA} *Weekly Business Intelligence Brief*\n_${dateStr}_\n\n${brief}`);
      console.log('[WEEKLY_BRIEF] Sent.');
    } catch (e) { logError('weekly_brief', e); }
  }, 60000);

  setInterval(() => { processWorkQueue(bot).catch(e => logError('work_queue_interval', e)); }, config.WORK_QUEUE_INTERVAL);

  // ─── BACKUP (every hour) ───────────────────────────────────────────────
  setInterval(saveBackupConfig, 3600000);

  // ─── HEALTH SERVER ─────────────────────────────────────────────────────
  const server = http.createServer((req, res) => {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      status: 'ok', bot: 'Sol v5.0', mode: 'autonomous+vision+browser',
      model: config.MODEL, uptime: Math.floor(process.uptime()),
      health: healthStatus,
      tasks: { active: activeTasks.length, queued: taskQueue.length },
      projects: Object.keys(loadProjects()).length,
      timestamp: new Date().toISOString()
    }));
  });
  server.listen(config.PORT, '0.0.0.0', () => { console.log(`🟢 Health: http://0.0.0.0:${config.PORT}/`); });
  server.on('error', (e) => {
    if (e.code === 'EADDRINUSE') console.log(`⚠️ Port ${config.PORT} in use (bot still works)`);
  });

  // Shutdown handlers
  process.on('SIGINT', () => { fs.writeFileSync(path.join(__dirname, '.last_clean_shutdown'), String(Date.now())); process.exit(0); });
  process.on('SIGTERM', () => { fs.writeFileSync(path.join(__dirname, '.last_clean_shutdown'), String(Date.now())); process.exit(0); });

  console.log('🟢 Sol v5.0 is online. Vision + Browser + SEO + Autonomous.');
  return bot;
}

process.on('uncaughtException', (e) => { logError('uncaught', e); });
process.on('unhandledRejection', (e) => { logError('unhandled', e); });

main().catch(e => { logError('fatal', e); process.exit(1); });

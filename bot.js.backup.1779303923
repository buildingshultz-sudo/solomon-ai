// ─── ERROR LOGGING ────────────────────────────────────────────────────────────
function logError(context, error) {
  const entry = `[${new Date().toISOString()}] [${context}] ${error?.message || error}\n`;
  fs.appendFileSync(ERROR_LOG, entry);
  console.error(`[ERROR][${context}] ${error?.message || error}`);
}

// ─── DATABASE SETUP ───────────────────────────────────────────────────────────
const db = new Database(DB_PATH);
db.pragma('journal_mode = WAL');
db.exec(`
  CREATE TABLE IF NOT EXISTS messages (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    chat_id TEXT NOT NULL,
    role TEXT NOT NULL,
    content TEXT NOT NULL,
    timestamp INTEGER DEFAULT (unixepoch())
  );
  CREATE INDEX IF NOT EXISTS idx_chat_id ON messages(chat_id);
`);

const insertMsg = db.prepare('INSERT INTO messages (chat_id, role, content) VALUES (?, ?, ?)');
const getHistory = db.prepare('SELECT role, content FROM messages WHERE chat_id = ? ORDER BY id DESC LIMIT ?');
const countMessages = db.prepare('SELECT COUNT(*) as cnt FROM messages WHERE chat_id = ?');
const deleteOldest = db.prepare(`DELETE FROM messages WHERE id IN (SELECT id FROM messages WHERE chat_id = ? ORDER BY id ASC LIMIT ?)`);

function saveMessage(chatId, role, content) {
  const id = String(chatId);
  insertMsg.run(id, role, content);
  const { cnt } = countMessages.get(id);
  if (cnt > config.MAX_MESSAGES) deleteOldest.run(id, cnt - config.MAX_MESSAGES);
}

function getChatHistory(chatId) {
  return getHistory.all(String(chatId), config.MAX_MESSAGES).reverse();
}

// ─── KNOWLEDGE BASE ──────────────────────────────────────────────────────────
function loadKnowledgeBase() {
  try { if (fs.existsSync(KB_PATH)) return JSON.parse(fs.readFileSync(KB_PATH, 'utf-8')); } catch (e) { logError('kb_load', e); }
  return { facts: [], decisions: [], updated: null };
}

function saveKnowledgeBase(kb) {
  kb.updated = new Date().toISOString();
  fs.writeFileSync(KB_PATH, JSON.stringify(kb, null, 2));
}

function addToKnowledgeBase(category, entry) {
  const kb = loadKnowledgeBase();
  if (!kb[category]) kb[category] = [];
  kb[category].push({ text: entry, date: new Date().toISOString() });
  if (kb[category].length > 200) kb[category] = kb[category].slice(-200);
  saveKnowledgeBase(kb);
}

function getKnowledgeSummary() {
  const kb = loadKnowledgeBase();
  let summary = '';
  if (kb.facts?.length) summary += 'KEY FACTS:\n' + kb.facts.slice(-20).map(f => `• ${f.text}`).join('\n') + '\n\n';
  if (kb.decisions?.length) summary += 'RECENT DECISIONS:\n' + kb.decisions.slice(-10).map(d => `• ${d.text}`).join('\n') + '\n\n';
  return summary;
}

// ─── REMINDERS ───────────────────────────────────────────────────────────────
function loadReminders() {
  try { if (fs.existsSync(REMINDERS_PATH)) return JSON.parse(fs.readFileSync(REMINDERS_PATH, 'utf-8')); } catch (e) { logError('reminders_load', e); }
  return [];
}
function saveReminders(reminders) { fs.writeFileSync(REMINDERS_PATH, JSON.stringify(reminders, null, 2)); }

function addReminder(chatId, text, triggerTime) {
  const reminders = loadReminders();
  reminders.push({ chatId: String(chatId), text, triggerTime, created: Date.now() });
  saveReminders(reminders);
}

function parseReminderTime(timeStr) {
  const now = Date.now();
  const match = timeStr.match(/(\d+)\s*(min|minute|minutes|h|hour|hours|d|day|days)/i);
  if (match) {
    const num = parseInt(match[1]);
    const unit = match[2].toLowerCase();
    if (unit.startsWith('min')) return now + num * 60000;
    if (unit.startsWith('h')) return now + num * 3600000;
    if (unit.startsWith('d')) return now + num * 86400000;
  }
  return now + 3600000;
}


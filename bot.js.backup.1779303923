// ─── PROACTIVE TIMER SYSTEM ──────────────────────────────────────────────────
const activeTimers = new Map(); // id -> { description, interval, timerId, chatId }
let timerCounter = 0;

function setProactiveTimer(bot, chatId, description, intervalMs, callback) {
  timerCounter++;
  const id = `timer_${timerCounter}`;
  const timerId = setInterval(async () => {
    try {
      if (callback) {
        await callback(bot, chatId);
      } else {
        await safeSend(bot, chatId, `⏰ *Timer Update:* ${description}`);
      }
    } catch (e) { logError('timer_' + id, e); }
  }, intervalMs);
  activeTimers.set(id, { description, interval: intervalMs, timerId, chatId, createdAt: Date.now() });
  console.log(`[TIMER] Set: ${id} | ${description} | every ${intervalMs / 1000}s`);
  return id;
}

function clearProactiveTimer(id) {
  const timer = activeTimers.get(id);
  if (timer) {
    clearInterval(timer.timerId);
    activeTimers.delete(id);
    console.log(`[TIMER] Cleared: ${id}`);
    return true;
  }
  return false;
}

function clearAllTimers() {
  for (const [id, timer] of activeTimers) {
    clearInterval(timer.timerId);
  }
  activeTimers.clear();
}

function getActiveTimers() {
  return Array.from(activeTimers.entries()).map(([id, t]) => ({
    id, description: t.description, intervalMs: t.interval, createdAt: t.createdAt
  }));
}

// ─── VOICE TRANSCRIPTION ─────────────────────────────────────────────────────
async function transcribeVoice(bot, fileId) {
  try {
    const fileUrl = await bot.getFileLink(fileId);
    const response = await fetch(fileUrl);
    const buffer = Buffer.from(await response.arrayBuffer());
    const tmpPath = path.join(__dirname, `voice_${Date.now()}.ogg`);
    fs.writeFileSync(tmpPath, buffer);
    const openaiKey = process.env.OPENAI_API_KEY;
    if (openaiKey) {
      const { execSync } = require('child_process');
      const result = execSync(
        `curl -s -X POST "https://api.openai.com/v1/audio/transcriptions" -H "Authorization: Bearer ${openaiKey}" -F "file=@${tmpPath}" -F "model=whisper-1"`,
        { encoding: 'utf-8', timeout: 30000 }
      );
      fs.unlinkSync(tmpPath);
      return JSON.parse(result).text || '';
    }
    fs.unlinkSync(tmpPath);
    return '[Voice received — transcription unavailable]';
  } catch (e) { logError('transcribe', e); return '[Could not transcribe]'; }
}

// ─── PC BRIDGE ───────────────────────────────────────────────────────────────
async function pcAgentStatus() {
  try {
    const res = await fetch(`${config.RELAY_URL}/agent/status`);
    const data = await res.json();
    return data;
  } catch { return { ok: false, online: false }; }
}

async function executeOnPC(command, type = 'powershell', timeoutMs = 60000) {
  try {
    const status = await pcAgentStatus();
    if (!status.online) return { success: false, output: 'PC agent is offline.' };
    const qRes = await fetch(`${config.RELAY_URL}/command/queue`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ command, type })
    });
    const qData = await qRes.json();
    if (!qData.ok) return { success: false, output: 'Failed to queue command.' };
    const cmdId = qData.id;
    const start = Date.now();
    while (Date.now() - start < timeoutMs) {
      await new Promise(r => setTimeout(r, 1500));
      const rRes = await fetch(`${config.RELAY_URL}/command/result/${cmdId}`);
      const rData = await rRes.json();
      if (rData.status === 'completed') {
        const r = rData.result;
        return { success: r.exitCode === 0, output: r.stdout || r.stderr || '(no output)', exitCode: r.exitCode };
      }
    }
    return { success: false, output: 'Command timed out (60s).' };
  } catch (e) {
    logError('pc_bridge', e);
    return { success: false, output: `Bridge error: ${e.message}` };
  }
}

// Execute multiple commands in sequence on PC, returning all results
async function executeMultiOnPC(commands) {
  const results = [];
  for (const cmd of commands) {
    const r = await executeOnPC(cmd.command || cmd, cmd.type || 'powershell', cmd.timeout || 60000);
    results.push({ command: cmd.command || cmd, ...r });
    if (!r.success && cmd.stopOnFail !== false) break;
  }
  return results;
}

// ─── DEV WORKFLOW (GitHub, npm, builds) ──────────────────────────────────────
async function devGitClone(repo, targetDir) {
  return executeOnPC(`git clone https://github.com/${repo}.git "${targetDir}"`, 'cmd', 120000);
}

async function devNpmInstall(dir) {
  return executeOnPC(`cd "${dir}" && npm install`, 'cmd', 120000);
}

async function devWriteFile(filePath, content) {
  // Escape content for PowerShell
  const escaped = content.replace(/'/g, "''");
  const cmd = `$content = @'\n${escaped}\n'@\nSet-Content -Path "${filePath}" -Value $content -Encoding UTF8`;
  return executeOnPC(cmd, 'powershell', 30000);
}

async function devRunCommand(command, dir = null, timeout = 60000) {
  const prefix = dir ? `cd "${dir}" && ` : '';
  return executeOnPC(`${prefix}${command}`, 'cmd', timeout);
}
// ─── SELF-UPDATE PC AGENT ────────────────────────────────────────────────────
// Sol can update his own PC agent code. The watchdog detects the file change
// and auto-restarts the agent. NEVER kill node.exe directly.
async function selfUpdateAgent(newCode) {
  const AGENT_PATH = 'C:\\Users\\Ashle\\SolomonAgent\\solomon-agent.js';
  // Write new code via PowerShell here-string
  const escaped = newCode.replace(/'/g, "''");
  const writeCmd = `$c = @'\n${escaped}\n'@\nSet-Content -Path "${AGENT_PATH}" -Value $c -Encoding UTF8`;
  const writeResult = await executeOnPC(writeCmd, 'powershell', 30000);
  if (!writeResult.success) {
    return { success: false, message: `Failed to write agent file: ${writeResult.output}` };
  }
  // Wait 15 seconds for watchdog to detect change and restart agent
  await new Promise(r => setTimeout(r, 15000));
  // Verify agent came back online
  const status = await pcAgentStatus();
  if (status.online) {
    return { success: true, message: 'Agent updated and restarted successfully.' };
  } else {
    return { success: false, message: 'Agent file written but agent did not come back online. Watchdog may not be running. Alert Jed.' };
  }
}


// ─── SEND WITH MARKDOWN FALLBACK ──────────────────────────────────────────────

// ─── MESSAGE DEDUP GUARD ─────────────────────────────────────────────────────
const recentSentMessages = new Set();
function isDuplicateMessage(chatId, text) {
  const key = `${chatId}:${text.slice(0, 100)}`;
  if (recentSentMessages.has(key)) return true;
  recentSentMessages.add(key);
  setTimeout(() => recentSentMessages.delete(key), 10000); // 10s dedup window
  return false;
}

async function safeSend(bot, chatId, text) {
  if (isDuplicateMessage(chatId, text)) { console.log('[DEDUP] Blocked duplicate message'); return; }
  if (!text || !text.trim()) return;
  const chunks = text.length > 4000 ? text.match(/[\s\S]{1,4000}/g) : [text];
  for (const chunk of chunks) {
    try {
      await bot.sendMessage(chatId, chunk, { parse_mode: 'Markdown' });
    } catch (e) {
      if (e.message?.includes('parse') || e.message?.includes("can't parse")) {
        try { await bot.sendMessage(chatId, chunk); } catch (e2) { logError('send_plain', e2); }
      } else { logError('send', e); }
    }
  }
}

// ─── CONTEXT BUILDER ──────────────────────────────────────────────────────────
function buildContext(chatId) {
  const now = new Date();
  const timeStr = now.toLocaleString('en-US', {
    timeZone: 'America/Chicago', weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit'
  });
  let ctx = `\n\n[CURRENT TIME: ${timeStr} CDT]\n`;

  const kbSummary = getKnowledgeSummary();
  if (kbSummary) ctx += `\n[PERSISTENT KNOWLEDGE]\n${kbSummary}`;

  // Project state
  const projects = loadProjects();
  const activeProjects = Object.entries(projects).filter(([_, p]) => p.status === 'active');
  if (activeProjects.length > 0) {
    ctx += `\n[ACTIVE PROJECTS]\n`;
    for (const [key, p] of activeProjects) {
      ctx += `• ${p.name} [${p.phase}]: Next → ${(p.nextSteps || []).slice(0, 2).join(', ')}\n`;
    }
  }

  const reminders = loadReminders().filter(r => String(r.chatId) === String(chatId));
  if (reminders.length > 0) {
    ctx += `\n[ACTIVE REMINDERS]\n`;
    for (const r of reminders.slice(0, 5)) {
      const when = new Date(r.triggerTime).toLocaleString('en-US', { timeZone: 'America/Chicago' });
      ctx += `• ${r.text} (due: ${when})\n`;
    }
  }

  if (activeTasks.length > 0) {
    ctx += `\n[ACTIVE SUB-TASKS: ${activeTasks.length}]\n`;
    activeTasks.forEach(t => { ctx += `• ${t.description}\n`; });
  }

  // Work queue status
  const wq = loadWorkQueue();
  const pendingWork = wq.items.filter(i => i.status === 'pending');
  if (pendingWork.length > 0) {
    ctx += `\n[WORK QUEUE: ${pendingWork.length} items pending]\n`;
    pendingWork.slice(0, 3).forEach(w => { ctx += `• ${w.description}\n`; });
  }

  return ctx;
}

// ─── AUTO-EXTRACT KNOWLEDGE ───────────────────────────────────────────────────
function autoExtractKnowledge(userMsg) {
  if (/\b(decided|decision|let's go with|we'll do|the plan is|moving forward)\b/i.test(userMsg)) {
    addToKnowledgeBase('decisions', userMsg.substring(0, 200));
  }
  if (/\b(my .+ is|i (have|got|made|earned|spent)|revenue|income|subscribers|views)\b/i.test(userMsg) && userMsg.length < 300) {
    addToKnowledgeBase('facts', userMsg.substring(0, 200));
  }
}

// ─── TEXT HANDLER ────────────────────────────────────────────────────────────
async function handleText(bot, chatId, text, prefix = '') {
  try {
    saveMessage(chatId, 'user', text);
    autoExtractKnowledge(text);
    const history = getChatHistory(chatId);

    // Smart content detection: if asking about videos/content, check PC for real data
    let contextInjection = '';

    // Inject knowledge base context
    const kbContext = getKBContext();
    contextInjection += kbContext;
    const videoKeywords = /\b(video|next video|upcoming|content|upload|footage|what.*(going out|publishing|posting)|seo|thumbnail)\b/i;
    if (videoKeywords.test(text)) {
      const agentStatus = await pcAgentStatus();
      if (agentStatus.online) {
        try {
          const folderResult = await executeOnPC('Get-ChildItem "C:\\Users\\Ashle\\Desktop\\UNEDITED VIDEOS" -Directory | Select-Object Name, LastWriteTime | Format-Table -AutoSize | Out-String');
          if (folderResult.success && folderResult.output && !folderResult.output.includes('Cannot find path')) {
            contextInjection += `\n\n[REAL DATA - Unedited footage folders on PC:]\n${folderResult.output.slice(0, 1500)}\n`;
          }
        } catch {}
      }
      // Check project memory for planned videos
      const projects = loadProjects();
      const videoProjects = Object.entries(projects).filter(([k, v]) => v.type === 'video' || v.category === 'content');
      if (videoProjects.length > 0) {
        contextInjection += `\n[Project memory - planned videos:]\n${videoProjects.map(([k, v]) => `- ${k}: ${v.status} - ${v.description || ''}`).join('\n')}\n`;
      }
      if (!contextInjection) {
        contextInjection += `\n[NOTE: Could not check PC footage folder (agent ${agentStatus.online ? 'online but folder empty/missing' : 'offline'}). If you do not know what video Jed is working on, ASK HIM directly. Do NOT guess or give generic advice.]\n`;

    // Web search injection: if asking to research/find/look up something, do a real search
    const researchKeywords = /\b(research|look up|find out|search for|what is|who is|latest|current|trending|news about)\b/i;
    if (researchKeywords.test(text) && !text.startsWith('/')) {
      try {
        const searchQuery = text.replace(/^(can you |please |sol |hey )?(research|look up|find out about|search for|tell me about)/i, '').trim().slice(0, 100);
        if (searchQuery.length > 5) {
          const searchResults = await webSearch(searchQuery, 5);
          if (searchResults.success && searchResults.results.length > 0) {
            contextInjection += `\n\n[LIVE WEB SEARCH RESULTS for "${searchQuery}":]\n`;
            searchResults.results.forEach((r, i) => {
              contextInjection += `${i+1}. ${r.title} - ${r.snippet}\n   URL: ${r.url}\n`;
            });
            contextInjection += `\n[Use these REAL search results to inform your response. Cite sources.]\n`;
          }
        }
      } catch (searchErr) { /* silent fail */ }
    }
      }
    }

    const messages = [
      { role: 'system', content: config.SYSTEM_PROMPT + buildContext(chatId) + contextInjection },
      ...history.map(m => ({ role: m.role, content: m.content }))
    ];
    const typing = setInterval(() => { bot.sendChatAction(chatId, 'typing').catch(() => {}); }, 4000);
    try {
      let rawReply;
      try {
        rawReply = await callLLM(messages);
      } catch (firstErr) {
        // First attempt failed — notify Jed and retry once
        logError('llm_first', firstErr);
        await safeSend(bot, chatId, 'Still processing, give me a moment...');
        await new Promise(r => setTimeout(r, 3000));
        try {
          rawReply = await callLLM(messages, config.MODEL_FALLBACK, 0);
        } catch (secondErr) {
          clearInterval(typing);
          logError('llm_retry', secondErr);
          await safeSend(bot, chatId, 'Hit a connectivity snag. Trying again in 30 seconds.');
          await new Promise(r => setTimeout(r, 30000));
          try {
            rawReply = await callLLM(messages, config.MODEL_FALLBACK, 0);
          } catch (finalErr) {
            clearInterval(typing);
            logError('llm_final', finalErr);
            await safeSend(bot, chatId, "Still having connection issues. I'm aware and will retry when the connection stabilizes. Try again in a minute.");
            return;
          }
        }
      }
      clearInterval(typing);
      // Strip [EXECUTE_PC:...] markers from what Jed sees — execute them silently
      const cleanReply = rawReply.replace(/\[EXECUTE_PC:[^\]]+\]/gi, '').replace(/\n{3,}/g, '\n\n').trim();
      saveMessage(chatId, 'assistant', cleanReply);
      await safeSend(bot, chatId, prefix + cleanReply);

      // Auto-detect and silently execute PC commands from Sol's response
      await autoExecutePCCommands(bot, chatId, rawReply);
    } catch (e) {
      clearInterval(typing);
      logError('llm', e);
      await safeSend(bot, chatId, 'Something went wrong processing that. Try again in a moment.');
    }
  } catch (e) {
    logError('handleText', e);
    try { await bot.sendMessage(chatId, 'Something went wrong. Try again in a moment.'); } catch {}
  }
}

// ─── AUTO PC COMMAND DETECTION ───────────────────────────────────────────────
async function autoExecutePCCommands(bot, chatId, reply) {
  // Extract and silently execute [EXECUTE_PC: ...] markers — Jed never sees the raw commands
  const pcMatches = [...reply.matchAll(/\[EXECUTE_PC:\s*([^\]]+)\]/gi)];
  for (const match of pcMatches) {
    const cmd = match[1].trim();
    console.log(`[AUTO_PC] Silently executing: ${cmd.slice(0, 100)}`);
    try {
      const result = await executeOnPC(cmd);
      // Only log to console — never show raw output to Jed unless it's meaningful
      if (!result.success) {
        console.log(`[AUTO_PC] Command failed (exit ${result.exitCode}): ${result.output?.slice(0, 200)}`);
      } else {
        console.log(`[AUTO_PC] Done. Exit 0.`);
      }
    } catch (e) {
      logError('auto_pc', e);
    }
  }
}

// ─── HEALTH MONITORING ──────────────────────────────────────────────────────
async function healthCheck(bot) {
  const status = { telegram: false, openrouter: false, timestamp: Date.now() };
  try {
    const me = await bot.getMe();
    status.telegram = !!me?.id;
  } catch (e) {
    logError('health_telegram', e);
    try { await bot.stopPolling(); await new Promise(r => setTimeout(r, 3000)); await bot.startPolling(); } catch {}
  }
  try {
    const res = await fetch(config.OPENROUTER_URL, {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${config.OPENROUTER_API_KEY}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ model: config.MODEL_FALLBACK, messages: [{ role: 'user', content: 'ping' }], max_tokens: 5 })
    });
    status.openrouter = res.ok;
  } catch (e) { logError('health_openrouter', e); }
  healthStatus = status;
  lastHealthCheck = Date.now();
  if (!status.telegram || !status.openrouter) {
    console.log(`[HEALTH] ISSUES: TG=${status.telegram} LLM=${status.openrouter}`);
  }
  return status;
}


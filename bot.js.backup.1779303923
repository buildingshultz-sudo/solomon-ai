// ─── TASK QUEUE (sub-agent system) ───────────────────────────────────────────
let taskQueue = [];
let activeTasks = [];
let completedTasks = [];

function loadTasks() {
  try { if (fs.existsSync(TASKS_PATH)) return JSON.parse(fs.readFileSync(TASKS_PATH, 'utf-8')); } catch {}
  return { queue: [], active: [], completed: [] };
}

function saveTasks() {
  fs.writeFileSync(TASKS_PATH, JSON.stringify({ queue: taskQueue, active: activeTasks, completed: completedTasks.slice(-20) }, null, 2));
}

async function addTask(description, context, chatId) {
  const task = { id: Date.now().toString(36), description, context, chatId: String(chatId), status: 'queued', created: Date.now() };
  taskQueue.push(task);
  saveTasks();
  processTaskQueue();
  return task;
}

async function processTaskQueue() {
  while (taskQueue.length > 0 && activeTasks.length < config.MAX_WORKERS) {
    const task = taskQueue.shift();
    task.status = 'active';
    activeTasks.push(task);
    saveTasks();
    executeTask(task).catch(e => logError('task_exec', e));
  }
}

async function executeTask(task) {
  try {
    const messages = [
      { role: 'system', content: `You are Sol, executing a sub-task. Be concise and actionable. Task: ${task.description}` },
      { role: 'user', content: task.context || task.description }
    ];
    const result = await callLLM(messages);
    task.status = 'completed';
    task.result = result;
    task.completedAt = Date.now();
  } catch (e) {
    task.status = 'failed';
    task.error = e.message;
  }
  activeTasks = activeTasks.filter(t => t.id !== task.id);
  completedTasks.push(task);
  saveTasks();
  return task;
}

// ─── LLM CALL ─────────────────────────────────────────────────────────────────
async function callLLM(messages, model = config.MODEL, retries = 1) {
  for (let attempt = 0; attempt <= retries; attempt++) {
    try {
      console.log(`[LLM] Calling ${model} (attempt ${attempt})`);
      const res = await fetch(config.OPENROUTER_URL, {
        method: 'POST',
        signal: AbortSignal.timeout(30000),
        headers: {
          'Authorization': `Bearer ${config.OPENROUTER_API_KEY}`,
          'Content-Type': 'application/json',
          'HTTP-Referer': 'https://solomon-bot.local',
          'X-Title': 'Sol Bot'
        },
        body: JSON.stringify({ model, messages, max_tokens: 4096, temperature: 0.7 })
      });
      if (!res.ok) {
        const errText = await res.text();
        throw new Error(`OpenRouter ${res.status}: ${errText}`);
      }
      const data = await res.json();
      const content = data.choices?.[0]?.message?.content;
      if (!content) throw new Error('Empty LLM response');
      console.log(`[LLM] Success (${content.length} chars)`);
      return content;
    } catch (e) {
      logError(`llm_attempt_${attempt}`, e);
      if (attempt < retries) {
        model = config.MODEL_FALLBACK;
        await new Promise(r => setTimeout(r, 2000));
      } else throw e;
    }
  }
}

// ─── WEB SEARCH ───────────────────────────────────────────────────────────────
async function webSearch(query) {
  try {
    const encoded = encodeURIComponent(query);
    const res = await fetch(`https://api.duckduckgo.com/?q=${encoded}&format=json&no_html=1`);
    const data = await res.json();
    let results = [];
    if (data.AbstractText) results.push(`[Summary] ${data.AbstractText}`);
    if (data.Answer) results.push(`[Answer] ${data.Answer}`);
    if (data.RelatedTopics) {
      for (const topic of data.RelatedTopics.slice(0, 8)) {
        if (topic.Text) results.push(`• ${topic.Text}`);
      }
    }
    return results.length > 0 ? results.join('\n\n') : 'No direct results. Try rephrasing.';
  } catch (e) { logError('search', e); return 'Search unavailable.'; }
}

// ─── IMAGE VISION (GPT-4o multimodal) ──────────────────────────────────────
async function analyzeImage(imageUrl, caption = '') {
  const userContent = [
    { type: 'text', text: caption || 'Analyze this image in detail. If it\'s a thumbnail, give specific feedback on composition, text, colors, and effectiveness. If it\'s a build/project, describe what you see and offer insights.' },
    { type: 'image_url', image_url: { url: imageUrl } }
  ];
  const messages = [
    { role: 'system', content: config.SYSTEM_PROMPT },
    { role: 'user', content: userContent }
  ];
  const res = await fetch(config.OPENROUTER_URL, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${config.OPENROUTER_API_KEY}`,
      'Content-Type': 'application/json',
      'HTTP-Referer': 'https://solomon-bot.local',
      'X-Title': 'Sol Bot'
    },
    body: JSON.stringify({ model: config.MODEL, messages, max_tokens: 4096, temperature: 0.7 })
  });
  if (!res.ok) throw new Error(`Vision API ${res.status}: ${await res.text()}`);
  const data = await res.json();
  return data.choices?.[0]?.message?.content || 'Could not analyze image.';
}


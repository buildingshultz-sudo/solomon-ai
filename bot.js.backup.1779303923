    if (timeMatch) {
      const triggerTime = parseReminderTime(timeMatch[1]);
      addReminder(msg.chat.id, timeMatch[2], triggerTime);
      const when = new Date(triggerTime).toLocaleString('en-US', { timeZone: 'America/Chicago' });
      await bot.sendMessage(msg.chat.id, `✓ Reminder set: "${timeMatch[2]}"\nDue: ${when} CDT`);
    } else {
      addReminder(msg.chat.id, input, Date.now() + 3600000);
      await bot.sendMessage(msg.chat.id, `✓ Reminder set for 1 hour: "${input}"`);

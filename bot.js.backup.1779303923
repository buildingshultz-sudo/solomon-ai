// ─── YOUTUBE SEO RESEARCH ───────────────────────────────────────────────────
async function youtubeSearch(query, maxResults = 15) {
  // Try YouTube Data API v3 first (real data with view counts, tags, etc.)
  if (config.YOUTUBE_API_KEY) {
    try {
      const encoded = encodeURIComponent(query);
      const searchRes = await fetch(
        `${config.YOUTUBE_API_URL}/search?part=snippet&q=${encoded}&type=video&maxResults=${maxResults}&order=relevance&key=${config.YOUTUBE_API_KEY}`
      );
      if (searchRes.ok) {
        const searchData = await searchRes.json();
        if (searchData.items && searchData.items.length > 0) {
          // Get video IDs for stats lookup
          const videoIds = searchData.items.map(i => i.id.videoId).join(',');
          const statsRes = await fetch(
            `${config.YOUTUBE_API_URL}/videos?part=statistics,contentDetails,snippet&id=${videoIds}&key=${config.YOUTUBE_API_KEY}`
          );
          const statsData = statsRes.ok ? await statsRes.json() : { items: [] };
          const statsMap = {};
          for (const v of (statsData.items || [])) statsMap[v.id] = v;

          return searchData.items.map(item => {
            const stats = statsMap[item.id.videoId] || {};
            const snippet = item.snippet || {};
            const vstats = stats.statistics || {};
            return {
              videoId: item.id.videoId,
              title: snippet.title,
              author: snippet.channelTitle,
              publishedText: snippet.publishedAt ? new Date(snippet.publishedAt).toLocaleDateString() : 'N/A',
              description: snippet.description || '',
              viewCount: vstats.viewCount ? parseInt(vstats.viewCount).toLocaleString() : 'N/A',
              likeCount: vstats.likeCount ? parseInt(vstats.likeCount).toLocaleString() : 'N/A',
              commentCount: vstats.commentCount ? parseInt(vstats.commentCount).toLocaleString() : 'N/A',
              duration: stats.contentDetails?.duration || 'N/A',
              tags: (stats.snippet?.tags || []).slice(0, 20),
              thumbnailUrl: snippet.thumbnails?.high?.url || snippet.thumbnails?.default?.url || ''
            };
          });
        }
      }
    } catch (e) { logError('yt_api_search', e); }
  }

  // Fallback: Invidious public API
  try {
    const encoded = encodeURIComponent(query);
    const instances = [
      'https://invidious.io.lol/api/v1/search',
      'https://inv.nadeko.net/api/v1/search',
      'https://invidious.privacyredirect.com/api/v1/search'
    ];
    for (const base of instances) {
      try {
        const res = await fetch(`${base}?q=${encoded}&type=video&sort_by=relevance`, { signal: AbortSignal.timeout(8000) });
        if (res.ok) {
          const data = await res.json();
          if (Array.isArray(data) && data.length > 0) return data.slice(0, maxResults);
        }
      } catch {}
    }
  } catch (e) { logError('yt_invidious', e); }

  return [];
}

async function deepSEOAnalysis(topic) {
  // Fetch real YouTube data
  const results = await youtubeSearch(topic, 15);
  const webResults = await webSearch(`YouTube "${topic}" woodworking DIY tradesman content strategy 2025`);

  // Build rich data block
  const hasApiData = results.length > 0 && results[0].viewCount !== undefined;
  let data = `YouTube search results for "${topic}" (${results.length} videos found, ${hasApiData ? 'YouTube Data API v3' : 'Invidious fallback'}):\n\n`;

  let totalViews = 0;
  let maxViews = 0;
  let topVideo = null;
  for (const v of results) {
    const views = parseInt((v.viewCount || '0').replace(/,/g, '')) || 0;
    totalViews += views;
    if (views > maxViews) { maxViews = views; topVideo = v; }
    data += `TITLE: ${v.title || 'N/A'}\n`;
    data += `CHANNEL: ${v.author || v.authorId || 'N/A'}\n`;
    data += `VIEWS: ${v.viewCount || v.viewCountText || 'N/A'} | LIKES: ${v.likeCount || 'N/A'} | COMMENTS: ${v.commentCount || 'N/A'}\n`;
    data += `PUBLISHED: ${v.publishedText || 'N/A'} | DURATION: ${v.duration || 'N/A'}\n`;
    if (v.tags && v.tags.length > 0) data += `TAGS: ${v.tags.join(', ')}\n`;
    data += `DESC: ${(v.description || '').slice(0, 300)}\n\n`;
  }

  const avgViews = results.length > 0 ? Math.round(totalViews / results.length) : 0;
  data += `\nSTATISTICS: ${results.length} videos analyzed | Avg views: ${avgViews.toLocaleString()} | Top video: ${maxViews.toLocaleString()} views`;
  if (topVideo) data += ` ("${topVideo.title}")\n`;
  data += `\nWEB RESEARCH:\n${webResults}`;

  const messages = [
    {
      role: 'system',
      content: `${config.SYSTEM_PROMPT}\n\nYou are performing DEEP YouTube SEO analysis with real data. Go deeper than vidIQ. This is for Building Shultz (@BuildingShultz, ~1,450 subs) — woodworking, metalworking, DIY builds, tradesmen, AI for makers. Be hyper-specific. Use the actual data provided.`
    },
    {
      role: 'user',
      content: `Deep SEO analysis for: "${topic}"\n\nREAL DATA:\n${data}\n\nProvide:\n1. TITLE PATTERNS — what exact title formulas are working (with examples from the data)\n2. VIEW COUNT ANALYSIS — what separates high-performers from low-performers in this data\n3. THUMBNAIL INTEL — based on top performers, what visual style/text/composition works\n4. OPTIMAL TITLE — give me 5 specific title options for Building Shultz on this topic\n5. DESCRIPTION TEMPLATE — first 150 chars (what shows in search) + full structure\n6. TAG STRATEGY — 25 specific tags ranked by priority\n7. CONTENT ANGLE — the specific angle Building Shultz should take to differentiate\n8. OPPORTUNITY SCORE — 1-10, with reasoning based on competition vs. channel size\n9. BEST UPLOAD TIME — based on publish dates of top performers\n10. NEXT STEP — one specific action Jed should take today`
    }
  ];
  return await callLLM(messages);
}

// ─── DAVINCI RESOLVE INTEGRATION ────────────────────────────────────────────
async function resolveCommand(operation, args = '') {
  // Call resolve-helper.py on the PC
  const scriptPath = 'C:\\Users\\Ashle\\SolomonAgent\\resolve-helper.py';
  const cmd = args ? `python "${scriptPath}" ${operation} ${args}` : `python "${scriptPath}" ${operation}`;
  return await executeOnPC(cmd, 'cmd', 120000);
}

async function resolveGetStatus() {
  const r = await resolveCommand('status');
  if (!r.success) return { online: false, message: r.output };
  try { return { online: true, ...JSON.parse(r.output) }; }
  catch { return { online: true, message: r.output }; }
}

// ─── BROWSER COMMANDS (via PC Agent — Multi-Step Automation) ──────────────────
async function browseURL(url) {
  const result = await executeOnPC(`browser_open ${url}`, 'cmd', 45000);
  if (!result.success) return { success: false, content: result.output };
  try {
    const parsed = JSON.parse(result.output);
    return { success: true, title: parsed.title, url: parsed.url, text: parsed.text, step: parsed.step };
  } catch {
    return { success: true, content: result.output };
  }
}


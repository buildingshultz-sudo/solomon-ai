const fs = require('fs');
const path = require('path');
const { exec } = require('child_process');

async function createNextJsApp(projectName) {
    return new Promise((resolve, reject) => {
        const command = `npx create-next-app@latest ${projectName}`;
        exec(command, (error, stdout, stderr) => {
            if (error) {
                reject(`Error creating Next.js app: ${stderr}`);
            } else {
                resolve(`Next.js app created: ${stdout}`);
            }
        });
    });
}

async function initializeGitRepo(projectPath) {
    return new Promise((resolve, reject) => {
        exec('git init', { cwd: projectPath }, (error, stdout, stderr) => {
            if (error) {
                reject(`Error initializing git repo: ${stderr}`);
            } else {
                resolve(`Git repo initialized: ${stdout}`);
            }
        });
    });
}

async function createGitHubRepo(projectName, githubToken) {
    const response = await fetch('https://api.github.com/user/repos', {
        method: 'POST',
        headers: {
            'Authorization': `token ${githubToken}`,
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ name: projectName })
    });

    if (!response.ok) {
        throw new Error(`Error creating GitHub repo: ${response.statusText}`);
    }

    const data = await response.json();
    return data.clone_url;
}

async function pushToGitHub(projectPath, remoteUrl) {
    return new Promise((resolve, reject) => {
        exec(`git remote add origin ${remoteUrl} && git add . && git commit -m "Initial commit" && git push -u origin main`, 
        { cwd: projectPath }, (error, stdout, stderr) => {
            if (error) {
                reject(`Error pushing to GitHub: ${stderr}`);
            } else {
                resolve(`Pushed to GitHub: ${stdout}`);
            }
        });
    });
}

async function deployToVercel(projectPath, vercelToken) {
    return new Promise((resolve, reject) => {
        exec(`vercel --token ${vercelToken} --prod`, { cwd: projectPath }, (error, stdout, stderr) => {
            if (error) {
                reject(`Error deploying to Vercel: ${stderr}`);
            } else {
                resolve(`Deployed to Vercel: ${stdout}`);
            }
        });
    });
}

async function automateDeployment(projectName, githubToken, vercelToken) {
    try {
        const projectPath = path.join(process.cwd(), projectName);
        await createNextJsApp(projectName);
        await initializeGitRepo(projectPath);
        const githubRepoUrl = await createGitHubRepo(projectName, githubToken);
        await pushToGitHub(projectPath, githubRepoUrl);
        const deploymentMessage = await deployToVercel(projectPath, vercelToken);
        return deploymentMessage;
    } catch (error) {
        return `Deployment failed: ${error.message}`;
    }
}

module.exports = { automateDeployment };
// Example function to convert natural language to cron expression
async function parseNaturalLanguageToCron(expression) {
  try {
    const cronExpression = await GPT4o.parse(expression);
    return cronExpression;
  } catch (error) {
    console.error('Error parsing natural language:', error);
    return null;
  }
}

// Handle /schedule command
async function handleScheduleCommand(command) {
  const [_, expression, ...taskData] = command.split(' ');
  const cronExpression = await parseNaturalLanguageToCron(expression);
  if (cronExpression) {
    await scheduler.scheduleTask('task-name', cronExpression, { data: taskData.join(' ') });
  }
}

// Handle /scheduled command
async function handleScheduledCommand() {
  const scheduledJobs = await scheduler.listScheduled();
  console.log('Scheduled Jobs:', scheduledJobs);
}

// Handle /unschedule command
async function handleUnscheduleCommand(command) {
  const [_, name] = command.split(' ');
  await scheduler.removeScheduled(name);
}

// Example function to start bot and handle commands
async function startBot() {
  // Simulate some command input
  await handleScheduleCommand('/schedule every day at 9am Do something');
  await handleScheduledCommand();
  await handleUnscheduleCommand('/unschedule task-name');
}

startBot().catch(console.error);
const { Queue, Worker, QueueScheduler, RepeatOptions } = require('bullmq');
const { promises: fs } = require('fs');
const path = require('path');

const REDIS_CONNECTION = { connection: { host: 'localhost', port: 6379 } };
const TASK_QUEUE_PATH = path.join(__dirname, 'task-queue.json');

// Create a new queue
const scheduledQueue = new Queue('sol-scheduled', REDIS_CONNECTION);

// Create a queue scheduler to handle repeatable jobs
new QueueScheduler('sol-scheduled', REDIS_CONNECTION);

// Function to schedule a task
async function scheduleTask(name, cronExpression, taskData) {
  try {
    await scheduledQueue.add(
      name,
      taskData,
      {
        repeat: { cron: cronExpression }
      }
    );
    console.log(`Scheduled task '${name}' with cron '${cronExpression}'`);
  } catch (error) {
    console.error('Error scheduling task:', error);
  }
}

// Function to list all scheduled jobs
async function listScheduled() {
  try {
    const jobs = await scheduledQueue.getRepeatableJobs();
    return jobs.map(job => ({
      name: job.name,
      nextRunAt: new Date(job.next)
    }));
  } catch (error) {
    console.error('Error listing scheduled jobs:', error);
    return [];
  }
}

// Function to remove a scheduled job
async function removeScheduled(name) {
  try {
    const jobs = await scheduledQueue.getRepeatableJobs();
    for (const job of jobs) {
      if (job.name === name) {
        await scheduledQueue.removeRepeatableByKey(job.key);
        console.log(`Removed scheduled task '${name}'`);
        return;
      }
    }
    console.log(`No scheduled task found with name '${name}'`);
  } catch (error) {
    console.error('Error removing scheduled job:', error);
  }
}

// Worker to process scheduled jobs
const worker = new Worker('sol-scheduled', async job => {
  try {
    const tasks = JSON.parse(await fs.readFile(TASK_QUEUE_PATH, 'utf8'));
    tasks.push({ name: job.name, data: job.data });
    await fs.writeFile(TASK_QUEUE_PATH, JSON.stringify(tasks, null, 2));
    console.log(`Processed job '${job.name}'`);
  } catch (error) {
    console.error('Error processing job:', error);
  }
}, REDIS_CONNECTION);

module.exports = {
  scheduleTask,
  listScheduled,
  removeScheduled
};


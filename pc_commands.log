[2026-05-20T17:44:54.206Z] {"action":"queued","id":"73755e27-66eb-4bdc-a109-da5ef8641e50","command":"$drives = Get-PSDrive -PSProvider FileSystem | Select-Object -ExpandProperty Root\n$found = @()\nforeach ($drive in $drives) {\n  foreach ($sp in @(\"${drive}Unedited Videos\",\"${drive}unedited videos\",\"${drive}Videos\")) {\n    if (Test-Path $sp) {\n      $files = Get-ChildItem -Path $sp -Recurse -Include *.mp4,*.mov,*.avi,*.mkv,*.mts,*.m2ts -ErrorAction SilentlyContinue | Where-Object { $_.Name -match \"(?i)judas|hammer\" }\n      foreach ($f in $files) { $found += $f.FullName }\n    }\n  }\n}\nif ($found.Count -eq 0) {\n  foreach ($drive in $drives) {\n    try {\n      $files = Get-ChildItem -Path $drive -Recurse -Include *.mp4,*.mov,*.avi,*.mkv,*.mts,*.m2ts -ErrorAction SilentlyContinue -Depth 6 | Where-Object { $_.Name -match \"(?i)judas|hammer\" }\n      foreach ($f in $files) { $found += $f.FullName }\n    } catch {}\n  }\n}\nWrite-Output (\"DRIVES: \" + ($drives -join \", \"))\nWrite-Output (\"FOUND_FILES: \" + ($found -join \"|\"))\nWrite-Output (\"COUNT: \" + $found.Count)","type":"powershell"}

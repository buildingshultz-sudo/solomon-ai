[2026-05-20T16:57:36.033Z] {"action":"queued","id":"f4e2fb04-4f4c-47ba-b364-334002f4d146","command":"Get-PSDrive -PSProvider FileSystem | Select-Object Name, @{N=\"Used_GB\";E={[math]::Round(..Used/1GB,1)}}, @{N=\"Free_GB\";E={[math]::Round(..Free/1GB,1)}} | Format-Table -AutoSize | Out-String","type":"powershell"}
[2026-05-20T16:57:40.222Z] {"action":"queued","id":"1185f45e-46e6-4dcc-8993-e1e19c5c6c82","command":"\n# Step 1: Find the Seagate 2TB drive\n$drives = Get-PSDrive -PSProvider FileSystem | Where-Object { $_.Used -gt 100GB } | Select-Object Name, @{N='SizeGB';E={[math]::Round($_.Used/1GB,1)}}, Root\nWrite-Output \"=== DRIVES FOUND ===\"\n$drives | ForEach-Object { Write-Output \"$($_.Name): $($_.Root) - $($_.SizeGB) GB used\" }\n\n# Step 2: Search for Judas Hammer folder on all large drives\n$searchDrives = @('D:', 'E:', 'F:', 'G:', 'H:')\n$foundFiles = @()\nforeach ($drive in $searchDrives) {\n  if (Test-Path $drive) {\n    Write-Output \"=== Searching $drive ===\"\n    # Search for folders containing 'judas' or 'hammer'\n    $folders = Get-ChildItem -Path $drive -Recurse -Directory -ErrorAction SilentlyContinue | \n      Where-Object { $_.Name -match 'judas|hammer|unedited' } |\n      Select-Object -First 10\n    foreach ($f in $folders) {\n      Write-Output \"FOLDER: $($f.FullName)\"\n      $videos = Get-ChildItem -Path $f.FullName -File -ErrorAction SilentlyContinue |\n        Where-Object { $_.Extension -match '\\.mp4|\\.mov|\\.avi|\\.mkv|\\.mts|\\.m2ts' }\n      foreach ($v in $videos) {\n        Write-Output \"  VIDEO: $($v.FullName) ($([math]::Round($v.Length/1MB,1)) MB)\"\n        $foundFiles += $v.FullName\n      }\n    }\n  }\n}\n\nif ($foundFiles.Count -eq 0) {\n  # Broader search — look for video files with 'judas' or 'hammer' in name\n  foreach ($drive in $searchDrives) {\n    if (Test-Path $drive) {\n      $videos = Get-ChildItem -Path $drive -Recurse -File -ErrorAction SilentlyContinue |\n        Where-Object { $_.Name -match 'judas|hammer' -and $_.Extension -match '\\.mp4|\\.mov|\\.avi|\\.mkv|\\.mts|\\.m2ts' } |\n        Select-Object -First 20\n      foreach ($v in $videos) {\n        Write-Output \"FOUND: $($v.FullName) ($([math]::Round($v.Length/1MB,1)) MB)\"\n        $foundFiles += $v.FullName\n      }\n    }\n  }\n}\n\nWrite-Output \"=== SUMMARY ===\"\nWrite-Output \"Total video files found: $($foundFiles.Count)\"\n$foundFiles | ForEach-Object { Write-Output $_ }\n","type":"powershell"}
[2026-05-20T16:57:41.341Z] {"action":"queued","id":"db48d78c-381a-45ae-96ae-ef1fe3935d43","command":"Get-PSDrive -PSProvider FileSystem | Format-Table | Out-String","type":"powershell"}

[2026-05-20T18:17:54.226Z] {"action":"queued","id":"7c6cb2e6-2ed2-4260-b9e7-045f9c3a5ab2","command":"$drives = Get-PSDrive -PSProvider FileSystem | Select-Object -ExpandProperty Root\n$found = @()\nforeach ($drive in $drives) {\n  foreach ($sp in @(\"${drive}Unedited Videos\",\"${drive}unedited videos\",\"${drive}Videos\")) {\n    if (Test-Path $sp) {\n      $files = Get-ChildItem -Path $sp -Recurse -Include *.mp4,*.mov,*.avi,*.mkv,*.mts,*.m2ts -ErrorAction SilentlyContinue | Where-Object { $_.Name -match \"(?i)judas|hammer\" }\n      foreach ($f in $files) { $found += $f.FullName }\n    }\n  }\n}\nif ($found.Count -eq 0) {\n  foreach ($drive in $drives) {\n    try {\n      $files = Get-ChildItem -Path $drive -Recurse -Include *.mp4,*.mov,*.avi,*.mkv,*.mts,*.m2ts -ErrorAction SilentlyContinue -Depth 6 | Where-Object { $_.Name -match \"(?i)judas|hammer\" }\n      foreach ($f in $files) { $found += $f.FullName }\n    } catch {}\n  }\n}\nWrite-Output (\"DRIVES: \" + ($drives -join \", \"))\nWrite-Output (\"FOUND_FILES: \" + ($found -join \"|\"))\nWrite-Output (\"COUNT: \" + $found.Count)","type":"powershell"}
[2026-05-20T18:18:57.120Z] {"action":"completed","id":"7c6cb2e6-2ed2-4260-b9e7-045f9c3a5ab2","exitCode":0,"stdout":""}
[2026-05-20T18:27:54.745Z] {"action":"queued","id":"e4304b94-dad0-4c55-81db-f6984f982566","command":"$ironEditPaths = @(\"C:\\Users\\Ashle\\IronEdit\",\"C:\\Users\\Ashle\\Desktop\\IronEdit\",\"C:\\IronEdit\")\n$found = $null\nforeach ($p in $ironEditPaths) { if (Test-Path $p) { $found = $p; break } }\nif ($found) {\n  Write-Output (\"IRONEDIT_PATH: \" + $found)\n  $exeFiles = Get-ChildItem -Path $found -Include *.exe -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1\n  if ($exeFiles) {\n    $WshShell = New-Object -ComObject WScript.Shell\n    $Shortcut = $WshShell.CreateShortcut(\"C:\\Users\\Ashle\\Desktop\\IronEdit.lnk\")\n    $Shortcut.TargetPath = $exeFiles.FullName\n    $Shortcut.WorkingDirectory = $found\n    $Shortcut.Description = \"IronEdit - AI Video Editor\"\n    $Shortcut.Save()\n    Write-Output \"SHORTCUT_CREATED: C:\\Users\\Ashle\\Desktop\\IronEdit.lnk\"\n  } else {\n    Write-Output \"IRONEDIT_STATUS: Found source only. Run npm install && npm start\"\n  }\n} else {\n  Write-Output \"IRONEDIT_STATUS: Not found in standard locations\"\n}","type":"powershell"}
[2026-05-20T18:27:56.193Z] {"action":"completed","id":"e4304b94-dad0-4c55-81db-f6984f982566","exitCode":0,"stdout":"IRONEDIT_PATH: C:\\Users\\Ashle\\IronEdit\r\nSHORTCUT_CREATED: C:\\Users\\Ashle\\Desktop\\IronEdit.lnk\r\n"}

[2026-05-21T14:50:55.588Z] {"action":"queued","id":"a91cbfbe-7069-4a8b-aa00-a8bbf74170cd","command":"Get-PSDrive -PSProvider FileSystem | ForEach-Object { Write-Output (\"DRIVE: \" + $_.Name + \" Root: \" + $_.Root + \" Used: \" + [math]::Round($_.Used/1GB,1) + \"GB Free: \" + [math]::Round($_.Free/1GB,1) + \"GB\") }","type":"powershell"}
[2026-05-21T14:52:10.197Z] {"action":"queued","id":"48111e1d-2ba2-4722-9cc3-2b12cab5035a","command":"$drive = \"E:\"\n$folders = @(\"UNEDITED VIDEOS\", \"Unedited Videos\", \"unedited videos\", \"Videos\", \"VIDEOS\", \"RAW\", \"Raw Footage\")\n$found = $null\nforeach ($f in $folders) {\n    $path = Join-Path $drive $f\n    if (Test-Path $path) { $found = $path; break }\n}\nif (-not $found) {\n    # Search one level deep\n    $items = Get-ChildItem -Path $drive -Directory -ErrorAction SilentlyContinue | Select-Object -First 10\n    Write-Output \"DRIVE_ROOT_FOLDERS:\"\n    $items | ForEach-Object { Write-Output (\"  \" + $_.Name) }\n} else {\n    Write-Output (\"FOUND_FOLDER: \" + $found)\n    $videos = Get-ChildItem -Path $found -Include *.mp4,*.mov,*.avi,*.mkv,*.mts -Recurse -ErrorAction SilentlyContinue | Select-Object Name, @{N='SizeMB';E={[math]::Round($_.Length/1MB,1)}} | Sort-Object SizeMB -Descending | Select-Object -First 20\n    Write-Output (\"VIDEO_COUNT: \" + $videos.Count)\n    $videos | ForEach-Object { Write-Output (\"VIDEO: \" + $_.Name + \" (\" + $_.SizeMB + \"MB)\") }\n}","type":"powershell"}
[2026-05-21T14:54:05.143Z] {"action":"queued","id":"699dfbc7-d04f-4e3b-a9aa-490b3cde1dcd","command":"$drives = @(\"D:\", \"E:\", \"F:\", \"G:\")\nforeach ($d in $drives) {\n    if (Test-Path $d) {\n        $label = (Get-Volume -DriveLetter $d.TrimEnd(\":\") -ErrorAction SilentlyContinue).FileSystemLabel\n        Write-Output (\"DRIVE: \" + $d + \" LABEL: \" + $label)\n    }\n}","type":"powershell"}
[2026-05-21T14:55:05.086Z] {"action":"queued","id":"97042f2b-fbb2-4f86-9ed8-5697fdc5ba0f","command":"$drives = @(\"D:\", \"E:\", \"F:\", \"G:\")\nforeach ($d in $drives) {\n    if (Test-Path $d) {\n        $label = (Get-Volume -DriveLetter $d.TrimEnd(\":\") -ErrorAction SilentlyContinue).FileSystemLabel\n        Write-Output (\"DRIVE: \" + $d + \" LABEL: \" + $label)\n    }\n}","type":"powershell"}
[2026-05-21T14:56:05.086Z] {"action":"queued","id":"c16161fd-b2f6-4157-a327-c4c97c441b3a","command":"$drives = @(\"D:\", \"E:\", \"F:\", \"G:\")\nforeach ($d in $drives) {\n    if (Test-Path $d) {\n        $label = (Get-Volume -DriveLetter $d.TrimEnd(\":\") -ErrorAction SilentlyContinue).FileSystemLabel\n        Write-Output (\"DRIVE: \" + $d + \" LABEL: \" + $label)\n    }\n}","type":"powershell"}
[2026-05-21T14:56:07.027Z] {"action":"completed","id":"c16161fd-b2f6-4157-a327-c4c97c441b3a","exitCode":0,"output":""}

const { ChartJSNodeCanvas } = require('chartjs-node-canvas');
const fetch = require('node-fetch');
const fs = require('fs');
const path = require('path');

const width = 1200; // Chart width
const height = 800; // Chart height

// Initialize ChartJSNodeCanvas
const chartJSNodeCanvas = new ChartJSNodeCanvas({ width, height });

async function renderChart(config, outputPath) {
  try {
    const image = await chartJSNodeCanvas.renderToBuffer(config);
    fs.writeFileSync(outputPath, image);
    return outputPath;
  } catch (error) {
    console.error('Error rendering chart:', error);
    throw error;
  }
}

async function generateDataReport(data, title, description) {
  try {
    const response = await fetch('https://api.openai.com/v1/gpt-4o', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${process.env.OPENAI_API_KEY}`,
      },
      body: JSON.stringify({
        prompt: `Analyze the following data: ${JSON.stringify(data)}. Provide a Chart.js config JSON for the most appropriate chart type and a 3-paragraph analysis.`,
      }),
    });

    const result = await response.json();
    const { chartConfig, analysis } = result;

    const outputPath = path.join(__dirname, 'chart.png');
    await renderChart(chartConfig, outputPath);

    return { chartPath: outputPath, analysis, chartConfig };
  } catch (error) {
    console.error('Error generating data report:', error);
    throw error;
  }
}

function barChart(labels, datasets, title) {
  return {
    type: 'bar',
    data: {
      labels,
      datasets,
    },
    options: {
      title: {
        display: true,
        text: title,
      },
    },
  };
}

function lineChart(labels, datasets, title) {
  return {
    type: 'line',
    data: {
      labels,
      datasets,
    },
    options: {
      title: {
        display: true,
        text: title,
      },
    },
  };
}

function pieChart(labels, data, title) {
  return {
    type: 'pie',
    data: {
      labels,
      datasets: [{
        data,
        backgroundColor: [
          '#FF6384',
          '#36A2EB',
          '#FFCE56',
          '#FF9F40',
          '#FFCD56',
          '#4BC0C0',
          '#9966FF',
          '#FF6384',
          '#36A2EB',
          '#FFCE56'
        ],
      }],
    },
    options: {
      title: {
        display: true,
        text: title,
      },
    },
  };
}

module.exports = {
  renderChart,
  generateDataReport,
  barChart,
  lineChart,
  pieChart,
};


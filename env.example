# ── Solomon Forge — copy to .env (install.bat will generate one for you) ─────────
# (The platform reserves real .env files; on a self-hosted box, rename this
#  to .env after copying.)

# Database (matches docker-compose.yml service name)
DATABASE_URL=mysql://solomon:change-me@db:3306/solomon
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_PASSWORD=change-me

# Brain (self-hosted mode)
OPENAI_API_KEY=sk-replace-me

# Session signing secret. Generate with:  openssl rand -hex 32
JWT_SECRET=replace-with-random-32-bytes-hex

# HTTP port the Node server listens on inside the container
PORT=3000

# Optional — only set these if you want OAuth via the Manus platform.
# Leave blank for fully self-hosted mode (see DEPLOYMENT_GUIDE.md §6).
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=Jedidiah Shultz

# ── Solomon Forge — desktop / local mode ──────────────────────────────────────────
# When SOLOMON_LOCAL=1 the server uses an embedded SQLite DB (no MySQL needed)
# and the local owner-password auth path instead of Manus OAuth.
SOLOMON_LOCAL=1
SOLOMON_DATA_DIR=./.solomon-data
OWNER_PASSWORD=forge

# ── Model provider (cloud OR local) ─────────────────────────────────────────────
# MODEL_PROVIDER: "openai" (paid, cloud) or "ollama" (free, local).
# Override from Settings at runtime; this is just the boot default.
MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
